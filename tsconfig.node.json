{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "types": ["electron-vite/node"],
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@mariozechner/pi-ai/oauth": ["node_modules/@mariozechner/pi-ai/dist/oauth.d.ts"]
    }
  }
}
